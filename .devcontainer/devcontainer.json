{
  "name": "FlowSphere AI",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bookworm",
  "postCreateCommand": "corepack enable && corepack prepare pnpm@9.12.0 --activate && pnpm install --frozen-lockfile --ignore-scripts && pnpm db:generate",
  "containerEnv": {
    "CI": "true"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "Prisma.prisma"
      ]
    }
  },
  "forwardPorts": [3000, 4000, 5432, 6379],
  "portsAttributes": {
    "3000": {
      "label": "Frontend"
    },
    "4000": {
      "label": "Backend"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "6379": {
      "label": "Redis"
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  }
}
