# FlowSphere AI — Environment Variables Template
# Copy this file to .env.local and fill in your values

# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME="FlowSphere AI"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://flowsphere:password@localhost:5432/flowsphere_db"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Session ──────────────────────────────────────────────────
SESSION_SECRET="your-session-secret-change-this-in-production"
COOKIE_DOMAIN=localhost

# ─── OAuth — Google ───────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── OAuth — GitHub ───────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="FlowSphere AI <noreply@flowsphere.ai>"

# ─── AI Providers ─────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# ─── Storage ──────────────────────────────────────────────────
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_REGION=us-east-1

# ─── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY="32-character-encryption-key-here"

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,https://app.flowsphere.ai"

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Stripe (Billing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ─── Frontend (NEXT_PUBLIC_*) ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=""
